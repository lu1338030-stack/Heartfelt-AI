# ===== Heartfelt AI 环境变量示例 =====
# 拷贝为 .env 后填入实际值

# ---- Backend (NestJS) ----
BACKEND_PORT=3000
NODE_ENV=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=heartfelt
POSTGRES_PASSWORD=heartfelt_dev
POSTGRES_DB=heartfelt
DATABASE_URL=postgresql://heartfelt:heartfelt_dev@localhost:5432/heartfelt

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=heartfelt
MINIO_SECRET_KEY=heartfelt_dev
MINIO_BUCKET=heartfelt-papers

# Python AI Service
AI_SERVICE_URL=http://localhost:8000

# LLM (kdoo.ai OpenAI 兼容)
OPENAI_BASE_URL=https://your-kdoo-endpoint/v1
OPENAI_API_KEY=your-kdoo-api-key
OPENAI_MODEL=your-model-name

# CORS (前端地址)
CORS_ORIGIN=http://localhost:5173

# ---- Frontend (Vite) ----
VITE_API_BASE_URL=http://localhost:3000
VITE_AI_SERVICE_URL=http://localhost:8000

# ---- AI Service (Python FastAPI) ----
AI_SERVICE_PORT=8000
# HuggingFace 模型缓存目录
HF_HOME=./models
# 首次下载用国内镜像（可选）
HF_ENDPOINT=https://hf-mirror.com
