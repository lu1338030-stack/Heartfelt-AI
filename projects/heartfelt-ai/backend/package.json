{
  "name": "heartfelt-backend",
  "version": "0.1.0",
  "description": "Heartfelt AI - NestJS backend for paper plagiarism check + AI humanization",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "migration:generate": "pnpm typeorm migration:generate -d src/data-source.ts",
    "migration:run": "pnpm typeorm migration:run -d src/data-source.ts",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "mammoth": "^1.12.0",
    "minio": "^8.0.7",
    "multer": "^2.2.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "docx": "^9.7.1",
    "prettier": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
